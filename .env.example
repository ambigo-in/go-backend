# ========================================
# Ambigo V2 Go Backend - Environment Config
# ========================================

# MongoDB
MONGODB_URI=mongodb://localhost:27017/

# JWT Authentication (generate with: openssl rand -hex 32)
JWT_SECRET=<your-jwt-secret>
JWT_ALGORITHM=HS256
JWT_VALIDITY=3000000

# API Key (shared with Flutter apps)
API_KEY=<your-api-key>

# SMS Country (OTP Service)
SMS_COUNTRY_KEY=<your-sms-country-key>
SMS_COUNTRY_TOKEN=<your-sms-country-token>
SMS_API_BASE_URL=https://restapi.smscountry.com/v0.1/Accounts/%s/SMSes/
SMS_SENDER_ID=AMBHPL
SMS_COUNTRY_CODE=91

# Razorpay
RAZORPAY_KEY_ID=<your-razorpay-key-id>
RAZORPAY_KEY_SECRET=<your-razorpay-key-secret>
RAZORPAY_WEBHOOK_SECRET=<your-razorpay-webhook-secret>

# Zwitch (Bank Payouts)
ZWITCH_ACCOUNT_ID=<your-zwitch-account-id>
ZWITCH_KEY=<your-zwitch-key>
ZWITCH_SECRET=<your-zwitch-secret>
ZWITCH_API_BASE_URL=https://api.zwitch.io/v1

# Cloudshope (Call Masking)
CLOUDSHOPE_TOKEN=<your-cloudshope-token>
CLOUDSHOPE_NUMBER=<your-cloudshope-number>
CLOUDSHOPE_API_BASE_URL=https://apiv2.cloudshope.com/api/outboundCall

# Server
PORT=8080
DEBUG=true

# Firebase FCM
FIREBASE_CREDENTIALS_PATH=firebase-key.json

# Google Maps
GOOGLE_MAPS_API_KEY=<your-google-maps-api-key>
GOOGLE_ROUTES_API_URL=https://routes.googleapis.com/directions/v2:computeRoutes
GOOGLE_TRANSLATE_API_URL=https://translate.googleapis.com/translate_a/single
